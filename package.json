{
  "name": "episodic-claw",
  "version": "0.2.3",
  "description": "Episodic Memory Engine for OpenClaw",
  "license": "MPL-2.0",
  "main": "./index.ts",
  "type": "module",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.28 <2026.4.0"
    },
    "build": {
      "openclawVersion": "2026.3.28",
      "pluginSdkVersion": "2026.3.28"
    }
  },
  "scripts": {
    "build": "npm-run-all build:ts build:go",
    "build:ts": "tsc",
    "build:go:linux": "cross-env GOOS=linux GOARCH=amd64 go build -C go -o ../dist/episodic-core .",
    "build:go:win": "cross-env GOOS=windows GOARCH=amd64 go build -C go -o ../dist/episodic-core.exe .",
    "build:go": "npm-run-all build:go:linux build:go:win",
    "postinstall": "node scripts/postinstall.cjs",
    "test": "cross-env EPISODIC_USE_GO_RUN=1 node --experimental-transform-types test_phase4_5.ts",
    "test:old": "cross-env EPISODIC_USE_GO_RUN=1 node --experimental-transform-types test_phase3.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "index.ts",
    "src/**/*.ts",
    "dist/**/*.js",
    "!dist/runner_hardcoded.js",
    "!dist/runner.js",
    "scripts/postinstall.cjs",
    "openclaw.plugin.json",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.28 <2026.4.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.8",
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  }
}
